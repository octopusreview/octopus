# ─────────────────────────────────────────────────────────────────────────────
# Octopus environment template
#
# Two modes:
#   AUTH_MODE=local       → magic-link / Google / GitHub social OAuth (Docker dev)
#   AUTH_MODE=databricks  → headers from Databricks Apps OAuth proxy (production)
#
# The Databricks-managed deployment fills these via app.yaml resources + the
# `octopus-octopus-ai` secret scope. For local development, copy this to .env
# and fill in the values you need.
# ─────────────────────────────────────────────────────────────────────────────

# Auth mode toggle. "local" for docker-compose dev, "databricks" for prod.
AUTH_MODE=local

# Database
DATABASE_URL=postgresql://octopus:octopus@localhost:43332/octopus

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (only used when AUTH_MODE=local)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (SMTP) — used only when FEATURES_EMAIL=true
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=Octopus

# Redis — local dev only; unused on Databricks
REDIS_URL=

# Qdrant (local dev only; replaced by Databricks Vector Search in prod)
QDRANT_URL=http://localhost:43333

# GitHub OAuth (only used when AUTH_MODE=local)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub App (used on both local + Databricks for webhook + repo access)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
NEXT_PUBLIC_GITHUB_APP_SLUG=
GITHUB_STATE_SECRET=

# Bitbucket / GitLab / Linear / Jira / Slack — STUBBED in Databricks deploy
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=
BITBUCKET_REDIRECT_URI=http://localhost:3000/api/bitbucket/callback
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_REDIRECT_URI=http://localhost:3000/api/gitlab/callback
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_REDIRECT_URI=http://localhost:3000/api/linear/callback
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:3000/api/jira/callback
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:3000/api/slack/callback

# Pubby (real-time) — STUBBED; only used when FEATURES_PUBBY=true
PUBBY_APP_ID=
PUBBY_APP_KEY=
PUBBY_APP_SECRET=
NEXT_PUBLIC_PUBBY_KEY=

# Stripe — STUBBED; only used when FEATURES_BILLING=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend (transactional email) — STUBBED; only used when FEATURES_EMAIL=true
RESEND_API_KEY=

# Cloudflare R2 — STUBBED; only used when FEATURES_R2=true
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=octopus
R2_PUBLIC_URL=

# Cohere (reranking) — optional; gracefully skipped if missing
COHERE_API_KEY=

# Email sender defaults (used when seeding templates)
EMAIL_PERSONAL_FROM_NAME=
EMAIL_PERSONAL_FROM_EMAIL=
EMAIL_SYSTEM_FROM_NAME=Octopus
EMAIL_SYSTEM_FROM_EMAIL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAILS=

# Review worker
ENABLE_REVIEW_WORKERS=true
ENABLE_INTERNAL_CLI=false

# ─────────────────────────────────────────────────────────────────────────────
# Feature flags — defaults all OFF; flip to "true" to re-enable stubbed paths
# ─────────────────────────────────────────────────────────────────────────────
FEATURES_BILLING=false
FEATURES_EMAIL=false
FEATURES_PUBBY=false
FEATURES_R2=false
FEATURES_LINEAR=false
FEATURES_JIRA=false
FEATURES_SLACK=false
FEATURES_BITBUCKET=false
FEATURES_GITLAB=false

# ─────────────────────────────────────────────────────────────────────────────
# Databricks (AUTH_MODE=databricks only; all auto-injected on Databricks Apps)
# ─────────────────────────────────────────────────────────────────────────────
DATABRICKS_HOST=
DATABRICKS_CLIENT_ID=
DATABRICKS_CLIENT_SECRET=

# LLM endpoints (Databricks Model Serving + AI Gateway external models)
ANTHROPIC_SERVING_ENDPOINT=octopus-claude
OPENAI_SERVING_ENDPOINT=octopus-openai
GEMINI_SERVING_ENDPOINT=octopus-gemini
OPENAI_EMBEDDINGS_SERVING_ENDPOINT=octopus-openai-embeddings

# Vector Search
VECTOR_SEARCH_ENDPOINT=octopus-vs
VECTOR_SEARCH_CATALOG=octopus_ai_catalog
VECTOR_SEARCH_SCHEMA=vectors

# Lakebase Autoscale (project name; PGHOST/PGUSER/PGPASSWORD/PGDATABASE auto-injected by App resource)
LAKEBASE_PROJECT=octopus-app
LAKEBASE_BRANCH=production
LAKEBASE_ENDPOINT=ep-primary

# ─────────────────────────────────────────────────────────────────────────────
# Legacy LLM API keys — kept for local docker-compose dev only
# Production goes through AI Gateway (no direct keys in app process)
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
